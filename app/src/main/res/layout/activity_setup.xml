<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#29B6F6"
    android:gravity="center">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Step 1: Create Account"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="32dp"
        android:textAlignment="center"/>

    <EditText
        android:id="@+id/etNewUsername"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Choose a Username"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etNewPassword"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Choose a Password"
        android:inputType="textPassword"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etFullName"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Your Full Name"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etStudyLevel"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Your Study Level (e.g. Year 1)"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnNextToInterests"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Next: Pick Interests"
        android:backgroundTint="#03A9F4"
        android:textColor="#FFFFFF"/>

</LinearLayout>